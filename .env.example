# SlimClaw Plugin - Environment Variables

# === Logging ===
# Available levels: debug, info, warn, error
# LOG_LEVEL=info

# === Cache Breakpoints ===
# Minimum content length (chars) for cache breakpoint injection
# CACHE_MIN_CONTENT_LENGTH=1000

# === Embeddings ===
# API keys for embedding providers (required when embeddings.enabled = true)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
